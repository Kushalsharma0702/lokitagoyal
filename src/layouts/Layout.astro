---
import Header from "@components/Header.astro";
import { Font } from "astro:assets";
import { SITE_CONFIG } from "@config";
import Footer from "@components/Footer.astro";

const {
  title,
  description,
  siteLogo,
  navLinks,
  lang,
  author,
  socialLinks,
  socialImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = SITE_CONFIG;

const ogImgUrl = canonicalURL + socialImage;
---

<!doctype html>
<html lang={lang} class="scroll-pt-16 scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Lokita Goyal, frontend developer, Python developer, BCA student, web developer intern, Noida, India, HTML CSS JavaScript, portfolio" />
    <meta name="author" content={author} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <Font cssVariable="--font-gabarito" preload />
    <Font cssVariable="--font-be-vietnam-pro" preload />

    <!-- Open Graph (for LinkedIn/WhatsApp previews) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImgUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Lokita Goyal — Portfolio" />
    <meta name="twitter:description" content="Frontend Developer & Python Programmer · BCA Student · Open to Internships" />
    <meta name="twitter:image" content={ogImgUrl} />
  </head>
  <body class="bg-black font-sans">
    <Header siteLogo={siteLogo} navLinks={navLinks} />
    <main class="mx-auto max-w-3xl px-5">
      <slot />
    </main>
    <Footer author={author} socialLinks={socialLinks} />
  </body>
</html>
